<!DOCTYPE html>

<html lang="zh-TW">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no">
<title>虱目魚小子 AR 拍照 🐟</title>
<style>
  @import url('https://fonts.googleapis.com/css2?family=Noto+Sans+TC:wght@400;700;900&display=swap');
  *{margin:0;padding:0;box-sizing:border-box;}
  :root{
    --teal:#00b4a0; --yellow:#e8c500; --dark:#0a1a18;
  }
  body{
    background:var(--dark); color:#fff;
    font-family:'Noto Sans TC',sans-serif;
    overflow:hidden; height:100dvh;
    display:flex; flex-direction:column; align-items:center;
  }

header{
width:100%; padding:8px 16px;
display:flex; align-items:center; justify-content:space-between;
background:linear-gradient(90deg,rgba(0,180,160,.2),rgba(232,197,0,.15));
border-bottom:1px solid rgba(0,180,160,.35);
z-index:10; flex-shrink:0;
}
header h1{
font-size:1rem; font-weight:900;
background:linear-gradient(90deg,#00e5cc,#f5c518,#00b4a0);
-webkit-background-clip:text; -webkit-text-fill-color:transparent;
}
#status{font-size:.68rem;color:var(–teal);}

/* ── Stage ── */
#stage{
position:relative; flex:1; width:100%;
overflow:hidden; display:flex;
justify-content:center; align-items:center;
background:#000;
}

/* camera video - hidden, just for capture */
#video{
position:absolute; width:1px; height:1px; opacity:0; pointer-events:none;
}

/* main display canvas */
#canvas{
position:absolute; top:0; left:0;
width:100%; height:100%;
object-fit:contain;
}

/* doll overlay canvas */
#doll-canvas{
position:absolute; top:0; left:0;
width:100%; height:100%;
object-fit:contain; pointer-events:none;
}

/* face guide ring */
#guide{
position:absolute;
border:3px dashed rgba(0,229,204,0.6);
border-radius:50%;
pointer-events:none;
transition:all .1s;
display:none;
}

#face-badge{
position:absolute; top:10px; left:10px;
background:rgba(0,180,160,.2); border:1px solid var(–teal);
border-radius:20px; padding:3px 12px; font-size:.68rem; color:var(–teal);
backdrop-filter:blur(6px);
}

/* ── Loading ── */
#loading{
position:absolute; inset:0;
background:var(–dark);
display:flex; flex-direction:column;
align-items:center; justify-content:center; gap:14px; z-index:20;
}
.fish-loader{font-size:3.5rem; animation:swim .9s ease-in-out infinite alternate;}
@keyframes swim{from{transform:translateX(-12px) rotate(-5deg);}to{transform:translateX(12px) rotate(5deg);}}
#loading p{font-size:.88rem;color:rgba(255,255,255,.7);}

/* ── Bottom Controls ── */
#panel{
width:100%; background:rgba(10,26,24,.95);
border-top:1px solid rgba(0,180,160,.2);
padding:10px 14px 16px;
display:flex; flex-direction:column; gap:8px;
backdrop-filter:blur(14px); flex-shrink:0;
}
.row{display:flex; align-items:center; gap:8px; justify-content:center; flex-wrap:wrap;}

/* shutter button */
#shutter{
width:64px; height:64px; border-radius:50%;
background:linear-gradient(135deg,#fff,#e0e0e0);
border:4px solid rgba(0,180,160,.6);
box-shadow:0 0 0 3px rgba(0,229,204,.25), 0 4px 20px rgba(0,0,0,.5);
cursor:pointer; font-size:1.6rem;
display:flex; align-items:center; justify-content:center;
transition:all .15s; flex-shrink:0;
}
#shutter:active{transform:scale(.9); box-shadow:0 0 0 6px rgba(0,229,204,.4);}

.ctrl-btn{
padding:8px 14px; border-radius:8px;
border:1px solid rgba(255,255,255,.15);
background:rgba(255,255,255,.06); color:rgba(255,255,255,.7);
font-size:.75rem; font-family:‘Noto Sans TC’,sans-serif;
cursor:pointer; transition:all .2s;
}
.ctrl-btn.on{
background:rgba(0,180,160,.25); color:#00e5cc;
border-color:var(–teal);
}

/* size slider */
.sl-row{display:flex;align-items:center;gap:8px;}
.sl-row label{font-size:.68rem;color:rgba(255,255,255,.5);white-space:nowrap;}
.sl-row input[type=range]{
flex:1; height:3px; -webkit-appearance:none; appearance:none;
background:rgba(255,255,255,.15); border-radius:4px; cursor:pointer;
}
.sl-row input[type=range]::-webkit-slider-thumb{
-webkit-appearance:none; width:14px; height:14px; border-radius:50%;
background:var(–teal); box-shadow:0 0 8px var(–teal);
}

/* photo result modal */
#result-modal{
position:fixed; inset:0;
background:rgba(0,0,0,.85);
display:none; flex-direction:column;
align-items:center; justify-content:center;
gap:16px; z-index:100;
padding:20px;
}
#result-modal.show{display:flex;}
#result-img{
max-width:100%; max-height:65dvh;
border-radius:12px;
box-shadow:0 8px 40px rgba(0,229,204,.3);
}
.modal-row{display:flex;gap:12px;}
.modal-btn{
padding:12px 24px; border-radius:10px; border:none;
font-size:.9rem; font-weight:700; cursor:pointer;
font-family:‘Noto Sans TC’,sans-serif;
}
#btn-save{background:linear-gradient(135deg,#00b4a0,#00e5cc);color:#fff;}
#btn-close{background:rgba(255,255,255,.12);color:rgba(255,255,255,.7);}
.tip{font-size:.78rem;color:rgba(255,255,255,.5);text-align:center;}
</style>

</head>
<body>

<header>
  <h1>🐟 虱目魚小子 AR</h1>
  <span id="status">初始化中…</span>
</header>

<div id="stage">
  <video id="video" playsinline muted autoplay></video>
  <canvas id="canvas"></canvas>
  <canvas id="doll-canvas"></canvas>
  <div id="guide"></div>
  <div id="face-badge">👤 偵測中…</div>

  <div id="loading">
    <div class="fish-loader">🐟</div>
    <p id="load-msg">載入 AI 模型中…</p>
  </div>
</div>

<div id="panel">
  <div class="row">
    <button class="ctrl-btn on" id="btn-mirror">🪞 鏡像</button>
    <button class="ctrl-btn on" id="btn-bighead">🔮 大頭</button>
    <button class="ctrl-btn on" id="btn-eyebrows">🖤 粗眉</button>
    <button class="ctrl-btn on" id="btn-blush">🌸 腮紅</button>
    <button id="shutter" title="拍照">📸</button>
    <button class="ctrl-btn" id="btn-cam">🔄 換鏡頭</button>
    <button class="ctrl-btn on" id="btn-guide">🎯 引導圈</button>
  </div>
  <div class="sl-row">
    <label>🐟 身體大小</label>
    <input type="range" id="sl-size" min="50" max="200" value="100">
    <label id="vl-size">100%</label>
  </div>
  <div class="sl-row">
    <label>↕ 上下位置</label>
    <input type="range" id="sl-vert" min="-50" max="50" value="0">
    <label id="vl-vert">0</label>
  </div>
</div>

<!-- Result Modal -->

<div id="result-modal">
  <img id="result-img" src="" alt="拍照結果">
  <div class="modal-row">
    <button class="modal-btn" id="btn-save">💾 儲存照片</button>
    <button class="modal-btn" id="btn-close">✕ 關閉</button>
  </div>
  <p class="tip">長按圖片可儲存到相簿</p>
</div>

<script src="https://cdn.jsdelivr.net/npm/@mediapipe/face_mesh@0.4.1633559619/face_mesh.js" crossorigin="anonymous"></script>

<script src="https://cdn.jsdelivr.net/npm/@mediapipe/camera_utils/camera_utils.js" crossorigin="anonymous"></script>

<script>
/* ════════════════════════════════
   DOLL IMAGE (embedded base64)
════════════════════════════════ */
const DOLL_B64 = 'data:image/png;base64,';

/* ════════════════════════════════
   STATE
════════════════════════════════ */
const S = {
  mirror: true,
  bighead: true,
  eyebrows: true,
  blush: true,
  guide: true,
  bodyScale: 1.0,
  vertOffset: 0,
  facingMode: 'user',
  faces: [],
};

/* ── DOM ── */
const video     = document.getElementById('video');
const canvas    = document.getElementById('canvas');
const dollCanvas= document.getElementById('doll-canvas');
const ctx       = canvas.getContext('2d');
const dCtx      = dollCanvas.getContext('2d');
const guide     = document.getElementById('guide');
const badge     = document.getElementById('face-badge');
const statusEl  = document.getElementById('status');
const loading   = document.getElementById('loading');
const loadMsg   = document.getElementById('load-msg');
const modal     = document.getElementById('result-modal');
const resultImg = document.getElementById('result-img');

/* ── load doll image ── */
const dollImg = new Image();
dollImg.src = DOLL_B64;
// Doll face oval position in image coords (from analysis):
// Center: (0.518, 0.314) of image
// Size: 0.503w x 0.330h of image
const DOLL = {
  faceCX: 0.518,  // face oval center x ratio
  faceCY: 0.314,  // face oval center y ratio
  faceW:  0.503,  // face oval width ratio
  faceH:  0.330,  // face oval height ratio
};

/* ── sliders & toggles ── */
document.getElementById('sl-size').addEventListener('input', e => {
  S.bodyScale = e.target.value / 100;
  document.getElementById('vl-size').textContent = e.target.value + '%';
});
document.getElementById('sl-vert').addEventListener('input', e => {
  S.vertOffset = +e.target.value;
  document.getElementById('vl-vert').textContent = e.target.value;
});

[['btn-mirror','mirror'],['btn-bighead','bighead'],
 ['btn-eyebrows','eyebrows'],['btn-blush','blush'],['btn-guide','guide']].forEach(([id,key]) => {
  const btn = document.getElementById(id);
  btn.addEventListener('click', () => {
    S[key] = !S[key];
    btn.classList.toggle('on', S[key]);
  });
});

/* ── camera switch ── */
document.getElementById('btn-cam').addEventListener('click', async () => {
  S.facingMode = S.facingMode === 'user' ? 'environment' : 'user';
  S.mirror = S.facingMode === 'user';
  document.getElementById('btn-mirror').classList.toggle('on', S.mirror);
  await startCamera();
});

/* ── shutter ── */
document.getElementById('shutter').addEventListener('click', takePhoto);

/* ── modal ── */
document.getElementById('btn-close').addEventListener('click', () => modal.classList.remove('show'));
document.getElementById('btn-save').addEventListener('click', () => {
  const a = document.createElement('a');
  a.href = resultImg.src;
  a.download = '虱目魚小子_' + Date.now() + '.png';
  a.click();
});

/* ════════════════════════════════
   CANVAS RESIZE
════════════════════════════════ */
function resize() {
  const stage = document.getElementById('stage');
  canvas.width  = stage.offsetWidth;
  canvas.height = stage.offsetHeight;
  dollCanvas.width  = stage.offsetWidth;
  dollCanvas.height = stage.offsetHeight;
}
window.addEventListener('resize', resize);
resize();

/* ════════════════════════════════
   WARP helpers
════════════════════════════════ */
function warp(cx, cy, radius, strength) {
  const W = canvas.width, H = canvas.height;
  const imgData = ctx.getImageData(0, 0, W, H);
  const dst = ctx.createImageData(W, H);
  const src = imgData.data, out = dst.data;
  const r2 = radius * radius;
  for (let y = 0; y < H; y++) {
    for (let x = 0; x < W; x++) {
      const rx = x-cx, ry = y-cy;
      const dist2 = rx*rx + ry*ry;
      let sx=x, sy=y;
      if (dist2 < r2) {
        const dist = Math.sqrt(dist2);
        const t = dist / radius;
        const factor = 1 - strength*(1 - t*t);
        sx = cx + rx*factor; sy = cy + ry*factor;
      }
      const si = (Math.round(Math.max(0,Math.min(H-1,sy)))*W + Math.round(Math.max(0,Math.min(W-1,sx))))*4;
      const di = (y*W+x)*4;
      out[di]=src[si]; out[di+1]=src[si+1]; out[di+2]=src[si+2]; out[di+3]=src[si+3];
    }
  }
  ctx.putImageData(dst, 0, 0);
}

/* ════════════════════════════════
   BIG HEAD
════════════════════════════════ */
let offCvs = null;
function applyBigHead(lm, W, H) {
  if (!offCvs) { offCvs = document.createElement('canvas'); }
  offCvs.width=W; offCvs.height=H;
  const oc = offCvs.getContext('2d');
  oc.drawImage(canvas, 0, 0);
  let minX=1,maxX=0,minY=1,maxY=0;
  lm.forEach(p=>{ if(p.x<minX)minX=p.x; if(p.x>maxX)maxX=p.x; if(p.y<minY)minY=p.y; if(p.y>maxY)maxY=p.y; });
  const pad=0.18, scale=1.45;
  const sx=(minX-pad*(maxX-minX))*W, sy=(minY-pad*(maxY-minY))*H;
  const sw=(maxX-minX)*(1+pad*2)*W, sh=(maxY-minY)*(1+pad*2)*H;
  const cx=((minX+maxX)/2)*W, cy=((minY+maxY)/2)*H;
  ctx.drawImage(offCvs, sx,sy,sw,sh, cx-sw*scale/2, cy-sh*scale/2, sw*scale, sh*scale);
}

/* ════════════════════════════════
   EYEBROWS (thick cartoon)
════════════════════════════════ */
function drawEyebrows(lm, W, H) {
  // left brow: landmarks 46-53 ish, right brow 276-283
  const lBrowL = lm[46], lBrowR = lm[55], lBrowTop = lm[105];
  const rBrowL = lm[285], rBrowR = lm[276], rBrowTop = lm[334];
  const angle = Math.atan2((lm[454].y-lm[234].y)*H, (lm[454].x-lm[234].x)*W);
  const faceW = Math.abs(lm[454].x-lm[234].x)*W;
  const thickness = faceW * 0.085;

  ctx.save();
  ctx.strokeStyle = '#111';
  ctx.lineCap = 'round';
  ctx.lineWidth = thickness;

  // left brow
  ctx.beginPath();
  ctx.moveTo(lBrowL.x*W, lBrowL.y*H);
  ctx.quadraticCurveTo(lBrowTop.x*W, (lBrowTop.y-0.025)*H, lBrowR.x*W, lBrowR.y*H);
  ctx.stroke();

  // right brow
  ctx.beginPath();
  ctx.moveTo(rBrowR.x*W, rBrowR.y*H);
  ctx.quadraticCurveTo(rBrowTop.x*W, (rBrowTop.y-0.025)*H, rBrowL.x*W, rBrowL.y*H);
  ctx.stroke();
  ctx.restore();
}

/* ════════════════════════════════
   BLUSH (peachy)
════════════════════════════════ */
function drawBlush(lm, W, H) {
  ctx.save();
  ctx.globalAlpha = 0.45;
  ctx.globalCompositeOperation = 'multiply';
  [[lm[116],lm[123],lm[147]],[lm[345],lm[352],lm[376]]].forEach(([a,b,c]) => {
    const cx=(a.x+b.x+c.x)/3*W, cy=(a.y+b.y+c.y)/3*H;
    const r=Math.abs(a.x-b.x)*W*2.8+10;
    const g=ctx.createRadialGradient(cx,cy,0,cx,cy,r);
    g.addColorStop(0,'#ffb3c199');
    g.addColorStop(.5,'#ffb3c155');
    g.addColorStop(1,'#ffb3c100');
    ctx.fillStyle=g;
    ctx.beginPath(); ctx.ellipse(cx,cy,r*1.35,r*0.8,-0.15,0,Math.PI*2); ctx.fill();
  });
  ctx.restore();
}

/* ════════════════════════════════
   DOLL OVERLAY
   Align doll so its face-oval matches detected face
════════════════════════════════ */
function drawDollOverlay(lm, cw, ch) {
  if (!dollImg.complete || !dollImg.naturalWidth) return;

  // get face bounding box from landmarks
  let minX=1,maxX=0,minY=1,maxY=0;
  lm.forEach(p=>{ if(p.x<minX)minX=p.x; if(p.x>maxX)maxX=p.x; if(p.y<minY)minY=p.y; if(p.y>maxY)maxY=p.y; });
  const faceW = (maxX-minX)*cw;
  const faceCX = ((minX+maxX)/2)*cw;
  const faceCY = ((minY+maxY)/2)*ch;

  const dollNatW = dollImg.naturalWidth;
  const dollNatH = dollImg.naturalHeight;

  // The doll face oval is DOLL.faceW * dollNatW pixels wide in the original image
  // We want it to match faceW in canvas pixels (with scale factor)
  const targetFaceW = faceW * 1.15 * S.bodyScale;
  const dollDrawW = targetFaceW / DOLL.faceW;
  const dollDrawH = dollDrawW * (dollNatH / dollNatW);

  // Position: doll face oval center should align with detected face center
  const dollFaceCX_in_draw = DOLL.faceCX * dollDrawW;
  const dollFaceCY_in_draw = DOLL.faceCY * dollDrawH;

  const drawX = faceCX - dollFaceCX_in_draw;
  const drawY = faceCY - dollFaceCY_in_draw + S.vertOffset * (ch/200);

  dCtx.clearRect(0, 0, cw, ch);
  dCtx.drawImage(dollImg, drawX, drawY, dollDrawW, dollDrawH);

  // guide ring around face oval
  if (S.guide) {
    const ovalW = DOLL.faceW * dollDrawW;
    const ovalH = DOLL.faceH * dollDrawH;
    const ovalCX = drawX + dollFaceCX_in_draw;
    const ovalCY = drawY + dollFaceCY_in_draw;
    guide.style.display = 'block';
    guide.style.width  = ovalW + 'px';
    guide.style.height = ovalH + 'px';
    guide.style.left   = (ovalCX - ovalW/2) + 'px';
    guide.style.top    = (ovalCY - ovalH/2) + 'px';
    guide.style.borderRadius = '50%';
  } else {
    guide.style.display = 'none';
  }
}

/* ════════════════════════════════
   FACE MESH RESULTS
════════════════════════════════ */
function onResults(results) {
  const W = canvas.width, H = canvas.height;
  ctx.clearRect(0, 0, W, H);

  // draw camera frame (mirrored if front cam)
  ctx.save();
  if (S.mirror) { ctx.translate(W,0); ctx.scale(-1,1); }
  ctx.drawImage(results.image, 0, 0, W, H);
  ctx.restore();

  const faces = results.multiFaceLandmarks || [];
  badge.textContent = faces.length > 0 ? `👤 ${faces.length} 張臉偵測` : '👤 找不到臉…';

  if (faces.length === 0) {
    dCtx.clearRect(0, 0, W, H);
    guide.style.display = 'none';
    return;
  }

  // Use first face for doll (largest face)
  const rawLm = faces[0];
  const lm = S.mirror
    ? rawLm.map(p => ({x:1-p.x, y:p.y, z:p.z}))
    : rawLm;

  S.faces = [lm];

  // ── effects on camera image ──
  if (S.bighead)   applyBigHead(lm, W, H);
  if (S.eyebrows)  drawEyebrows(lm, W, H);
  if (S.blush)     drawBlush(lm, W, H);

  // ── doll overlay ──
  drawDollOverlay(lm, W, H);
}

/* ════════════════════════════════
   TAKE PHOTO: merge canvas + doll
════════════════════════════════ */
function takePhoto() {
  const W = canvas.width, H = canvas.height;
  const merge = document.createElement('canvas');
  merge.width=W; merge.height=H;
  const mc = merge.getContext('2d');
  mc.drawImage(canvas, 0, 0);
  mc.drawImage(dollCanvas, 0, 0);
  const dataURL = merge.toDataURL('image/png');
  resultImg.src = dataURL;
  modal.classList.add('show');
}

/* ════════════════════════════════
   CAMERA & MEDIAPIPE INIT
════════════════════════════════ */
let faceMesh, camInstance;

async function startCamera() {
  if (camInstance) camInstance.stop();
  const stream = await navigator.mediaDevices.getUserMedia({
    video:{ facingMode: S.facingMode, width:{ideal:1280}, height:{ideal:720} }
  });
  video.srcObject = stream;
  await video.play();

  camInstance = new Camera(video, {
    onFrame: async () => { await faceMesh.send({image: video}); },
    width:1280, height:720
  });
  camInstance.start();
}

async function init() {
  faceMesh = new FaceMesh({
    locateFile: f => `https://cdn.jsdelivr.net/npm/@mediapipe/face_mesh@0.4.1633559619/${f}`
  });
  faceMesh.setOptions({
    maxNumFaces: 1,
    refineLandmarks: true,
    minDetectionConfidence: .5,
    minTrackingConfidence: .5,
  });
  faceMesh.onResults(onResults);

  loadMsg.textContent = '啟動攝影機…';
  try {
    await startCamera();
    statusEl.textContent = '✅ 準備好！';
    loading.style.display = 'none';
  } catch(e) {
    loadMsg.textContent = '❌ 無法存取鏡頭：' + e.message;
    statusEl.textContent = '錯誤';
  }
}

window.addEventListener('load', init);
</script>

</body>
</html>
